  }).join('');
}

/* ─────────────────────────────────────────────────────────────
   MERCHANT MODAL
───────────────────────────────────────────────────────────── */
async function openMerchant(merchantId) {
  // Show loading state immediately
  document.getElementById('modal-content').innerHTML = `
    <div class="modal-header" style="padding:40px 32px;text-align:center">
      <div style="color:rgba(15,20,30,0.3);font-size:13px">Loading merchant PIT…</div>
    </div>`;
  document.getElementById('modal-overlay').classList.add('open');
  document.body.style.overflow = 'hidden';

  try {
    const data = await api('getMerchant', { merchantId });
    if (!data) return;
    renderMerchantModal(data.merchant, data.submissions, data.latestPit);
  } catch(err) {
    document.getElementById('modal-content').innerHTML = `
      <div class="modal-header"><div class="modal-title" style="color:#DC2626">Error loading merchant</div>
      <div class="modal-meta">${esc(err.message)}</div></div>`;
  }
}

function renderMerchantModal(merchant, submissions, latestPit) {
  const latestSub = submissions[0] || null;
  const pit = latestPit?.pit_json || null;
  const facts = pit?.facts || (latestSub ? parseJSON(latestSub.report_json, {}) : {});
  const caseSummary = pit?.caseSummary || null;
  const commercialIntel = pit?.commercialIntelligence || null;
  const findings = pit?.findings || [];
  const opportunities = pit?.opportunities || [];
  const dataQuality = pit?.dataQuality || null;
  const riskIntel = pit?.riskIntelligence || null;
  const metrics = pit?.metrics || {};

  const sl = STATUS_LABEL[latestSub?.status] || 'No submissions';
  const sc = STATUS_CLASS[latestSub?.status] || 'pending';

  // Fee reconciliation check
  const feeCheck = checkFeeReconciliation(facts);
  const reconBanner = feeCheck ? `
    <div class="modal-alert warn" style="margin-bottom:16px">
      <strong>⚠ Fee reconciliation mismatch</strong>
      Extracted total fees (${fmtD(feeCheck.total)}) differ from the sum of the fee breakdown (${fmtD(feeCheck.sum)}) by ${fmtD(Math.abs(feeCheck.diff))} (${feeCheck.pct.toFixed(1)}%). Verify before generating report.
    </div>` : '';

  // Build the unified PIT tab.
  // This folds the old Intelligence tab and detailed PIT Viewer into one source-of-truth view.
  const pitTab = pit ? `
    ${buildPITTab(pit, facts, caseSummary, commercialIntel, findings, opportunities, dataQuality, riskIntel, metrics)}
    ${buildPITViewerTab(pit, latestPit)}
  ` : `
    <div style="padding:40px;text-align:center;color:rgba(15,20,30,0.25)">
      No PIT analysis yet. The PIT now runs automatically after submission; if this is an older submission, generate the report to create a PIT snapshot.
    </div>`;

  // Build submissions history tab
  const subsTab = buildSubmissionsTab(submissions, merchant);

  document.getElementById('modal-content').innerHTML = `
    <div class="modal-header">
      <div class="modal-eyebrow">Merchant · ${esc(merchant.industry||'Unknown industry')} · <span class="status-badge ${sc}" style="font-size:10px">${sl}</span></div>
      <div class="modal-title">${esc(merchant.company_name)}</div>
      <div class="modal-meta">${esc(latestSub?.provider||'No submissions yet')}${latestSub?.period ? ' — ' + esc(latestSub.period) : ''}</div>
      ${merchant.contact_name || merchant.contact_email ? `<div class="modal-contact">${[merchant.contact_name, merchant.contact_email ? `<a href="mailto:${escA(merchant.contact_email)}">${esc(merchant.contact_email)}</a>` : '', merchant.contact_phone].filter(Boolean).join(' &nbsp;·&nbsp; ')}</div>` : ''}
      <div class="modal-stats">
        <div class="modal-stat"><span class="modal-stat-val">${fmtP(latestSub?.effective_rate)}</span><span class="modal-stat-lbl">Eff. rate</span></div>
        <div class="modal-stat"><span class="modal-stat-val">${fmtK(latestSub?.volume)}</span><span class="modal-stat-lbl">Card volume</span></div>
        <div class="modal-stat"><span class="modal-stat-val">${caseSummary?.quantifiedAnnualOpportunity ? fmtK(caseSummary.quantifiedAnnualOpportunity) : '—'}</span><span class="modal-stat-lbl">Annual opportunity</span></div>
        <div class="modal-stat"><span class="modal-stat-val">${submissions.length}</span><span class="modal-stat-lbl">Submissions</span></div>
      </div>
    </div>
    <div class="modal-tabs">
      <button class="modal-tab active" onclick="switchModalTab('pit',this)">PIT</button>
      <button class="modal-tab" onclick="switchModalTab('submissions',this)">Submissions (${submissions.length})</button>
      <button class="modal-tab" onclick="switchModalTab('report',this)">Report</button>
      <button class="modal-tab" onclick="switchModalTab('modules',this);loadModuleAccess(${merchant.id})">Modules</button>
    </div>
    <div class="modal-body">
      ${reconBanner}
      <div class="modal-tab-pane active" id="mtab-pit">${pitTab}</div>
      <div class="modal-tab-pane" id="mtab-submissions">${subsTab}</div>
      <div class="modal-tab-pane" id="mtab-report">${buildReportTab(latestSub, facts, merchant)}</div>
      <div class="modal-tab-pane" id="mtab-modules"><div style="padding:20px 0;color:rgba(15,20,30,0.3);font-size:12px">Loading modules…</div></div>
    </div>`;

  document.getElementById('modal-overlay').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function switchModalTab(tab, btn) {
  document.querySelectorAll('.modal-tab').forEach(b => b.classList.remove('active'));
  document.querySelectorAll('.modal-tab-pane').forEach(p => p.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('mtab-' + tab).classList.add('active');
}

/* ─────────────────────────────────────────────────────────────
   MODULE ACCESS
───────────────────────────────────────────────────────────── */
async function loadModuleAccess(merchantId) {
  const pane = document.getElementById('mtab-modules');
  if (!pane) return;
  pane.innerHTML = '<div style="padding:20px 0;color:rgba(15,20,30,0.3);font-size:12px">Loading modules…</div>';

  try {
    const data = await api('getModuleAccess', { merchantId });
    if (!data) return;
    pane.innerHTML = renderModuleAccess(merchantId, data.modules);
  } catch(err) {
    pane.innerHTML = `<div style="padding:20px 0;color:#DC2626;font-size:12px">Error: ${esc(err.message)}</div>`;
  }
}

function renderModuleAccess(merchantId, modules) {
  if (!modules.length) return '<div style="padding:20px 0;color:rgba(15,20,30,0.25)">No modules configured.</div>';

  const rows = modules.map(m => {
    const isPlanned = m.status === 'planned';
    const enabledAt = m.enabled_at ? new Date(m.enabled_at).toLocaleDateString('en-AU', {day:'numeric',month:'short',year:'numeric'}) : null;

    return `<div class="module-row">
      <div class="module-info">
        <div class="module-name">${esc(m.name)} <span class="module-status-badge ${m.status}">${esc(m.status)}</span></div>
        <div class="module-desc">${esc(m.description||'')}</div>
        ${m.enabled && enabledAt ? `<div class="module-meta">Enabled ${enabledAt}${m.enabled_by && m.enabled_by !== 'admin' ? ' · by ' + esc(m.enabled_by) : ''}</div>` : ''}
        ${isPlanned ? `<div class="module-meta" style="color:rgba(180,83,9,0.5)">Not yet built — enable when available</div>` : ''}
      </div>
      <label class="module-toggle" title="${isPlanned ? 'Module not yet built' : (m.enabled ? 'Disable for this merchant' : 'Enable for this merchant')}">
        <input
          type="checkbox"
          ${m.enabled ? 'checked' : ''}
          onchange="toggleModule(${merchantId}, '${escA(m.id)}', this.checked, this)"
        >
        <span class="module-toggle-slider"></span>
      </label>
    </div>`;
  }).join('');

  return `
    <div style="margin-bottom:12px">
      <div style="font-size:11px;color:rgba(15,20,30,0.3);line-height:1.6">
        Toggle modules on or off for this merchant. Active modules are available immediately; planned modules can be enabled now and will become accessible once built.
      </div>
    </div>
    ${rows}`;
}

async function toggleModule(merchantId, moduleId, enable, checkbox) {
  // Optimistic UI — disable the checkbox during the request to prevent double-clicks
  checkbox.disabled = true;
  try {
    const data = await api('toggleModuleAccess', { merchantId, moduleId, enable });
    if (!data) {
      // Auth expired — revert checkbox
      checkbox.checked = !enable;
      return;
    }
    // Success — reload the module list to show updated enabled_at timestamp
    await loadModuleAccess(merchantId);
  } catch(err) {
    // Revert checkbox on error
    checkbox.checked = !enable;
    checkbox.disabled = false;
    alert('Could not update module access: ' + err.message);
  }
}

function buildPITTab(pit, facts, caseSummary, commercialIntel, findings, opportunities, dataQuality, riskIntel, metrics) {
  // Headline summary
  const headlineSummary = caseSummary ? `
    <div class="modal-section">
      <div class="modal-section-label">Intelligence Summary</div>
      <div style="font-size:14px;font-weight:500;color:rgba(15,20,30,0.85);margin-bottom:6px">${esc(caseSummary.headline||'')}</div>
