    <div class="pit-panel">
      <div class="pit-panel-title">Risk Intelligence</div>
      ${risks.length ? risks.map(r => `<div class="pit-finding-item"><div><div class="pit-finding-title">${esc(r.type || r.title || r.id)}</div><div class="pit-opp-meta">${esc(r.severity || '')} · ${esc(r.confidence || '')}</div><div style="font-size:11.5px;color:rgba(15,20,30,0.42);margin-top:3px">${esc(r.implication || r.observation || '')}</div></div></div>`).join('') : '<div class="modal-section-text">No major risks visible.</div>'}
    </div>
    <div class="pit-panel">
      <div class="pit-panel-title">Data Gaps</div>
      ${gaps.length ? gaps.map(g => `<div class="pit-finding-item"><div><div class="pit-finding-title">${esc(g.label || g.missingData || g.id)}</div><div class="pit-opp-meta">${esc(g.severity || '')}</div><div style="font-size:11.5px;color:rgba(15,20,30,0.42);margin-top:3px">${esc(g.reason || g.implication || '')}</div></div></div>`).join('') : '<div class="modal-section-text">No major data gaps visible.</div>'}
    </div>
  </div>`;
}

function renderPitModulePlanSection(modulePlan) {
  if (!modulePlan.length) return '';
  return `<div class="pitv-section">
    <div class="pitv-section-title">Selected Module Plan</div>
    <div class="pitv-grid">
      ${modulePlan.map(m => `<div class="pit-panel">
        <div class="pit-row"><span class="pit-row-label">Module</span><span class="pit-row-val">${esc(m.id)}</span></div>
        <div class="pit-row"><span class="pit-row-label">Type</span><span class="pit-row-val">${esc(m.type || '—')}</span></div>
        <div class="pit-row"><span class="pit-row-label">Priority</span><span class="pit-row-val">${esc(m.priority || '—')}</span></div>
        <div style="font-size:11.5px;color:rgba(15,20,30,0.4);line-height:1.6;margin-top:8px">${esc(m.reason || '')}</div>
      </div>`).join('')}
    </div>
  </div>`;
}

function renderPitEvidenceGraphSection(graph) {
  if (!graph) return '';
  const counts = {
    observations: graph.observations?.length || 0,
    understandings: graph.understandings?.length || 0,
    priorities: graph.priorities?.length || 0
  };
  return `<div class="pitv-section">
    <div class="pitv-section-title">Evidence Graph</div>
    <div class="pitv-grid">
      ${renderPitPanel('Observations', counts.observations)}
      ${renderPitPanel('Understandings', counts.understandings)}
      ${renderPitPanel('Priorities', counts.priorities)}
      ${renderPitPanel('Evidence mode', 'Explainable')}
    </div>
  </div>`;
}

function renderPitRawSection(pit) {
  return `<details class="pitv-card" style="margin-top:18px">
    <summary><div class="pitv-card-head"><div><div class="pitv-card-title">Raw PIT JSON</div><div class="pitv-card-meta">Developer view</div></div><div class="pitv-badges">${badge('JSON')}</div></div></summary>
    <div class="pitv-card-body"><pre class="pitv-code">${esc(JSON.stringify(pit, null, 2))}</pre></div>
  </details>`;
}

function renderPitPanel(label, value) {
  return `<div class="pit-panel"><div class="pit-panel-title">${esc(label)}</div><div style="font-size:22px;font-weight:600;color:rgba(15,20,30,0.85)">${esc(value)}</div></div>`;
}

function renderPitRow(label, value) {
  return `<div class="pit-row"><span class="pit-row-label">${esc(label)}</span><span class="pit-row-val">${esc(value ?? '—')}</span></div>`;
}

function renderEvidence(evidence) {
  if (!Array.isArray(evidence) || !evidence.length) return '';
  return `<div class="pitv-evidence">
    ${evidence.map(e => `<div class="pitv-evidence-item"><span class="pitv-evidence-source">${esc(e.source || e.type || 'evidence')}</span><span>${esc(e.label || '')}${e.value != null ? ': ' + esc(e.value) : ''}${e.detail ? ' · ' + esc(e.detail) : ''}</span></div>`).join('')}
  </div>`;
}

function badge(value) {
  if (value == null || value === '') return '';
  const cls = String(value).toLowerCase().replace(/\s+/g,'-');
  return `<span class="pitv-badge ${escA(cls)}">${esc(value)}</span>`;
}

function labelise(str) {
  return String(str || '').replace(/([A-Z])/g, ' $1').replace(/^./, c => c.toUpperCase());
}

function buildSubmissionsTab(submissions, merchant) {
  if (!submissions.length) return '<div style="padding:40px;text-align:center;color:rgba(15,20,30,0.25)">No submissions yet.</div>';

  return `<table class="modal-table" style="margin-top:8px">
    <thead><tr style="border-bottom:1px solid rgba(15,20,30,0.08)">
      <th style="padding:8px 0;font-size:10px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:rgba(15,20,30,0.28);text-align:left">Date</th>
      <th style="padding:8px 0;font-size:10px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:rgba(15,20,30,0.28);text-align:left">Provider</th>
      <th style="padding:8px 0;font-size:10px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:rgba(15,20,30,0.28);text-align:left">Period</th>
      <th style="padding:8px 0;font-size:10px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:rgba(15,20,30,0.28);text-align:right">Volume</th>
      <th style="padding:8px 0;font-size:10px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:rgba(15,20,30,0.28);text-align:right">Rate</th>
      <th style="padding:8px 0;font-size:10px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:rgba(15,20,30,0.28);text-align:left">Status</th>
    </tr></thead>
    <tbody>
    ${submissions.map(s => {
      const dateStr = new Date(s.submitted_at).toLocaleDateString('en-AU', {day:'numeric',month:'short',year:'numeric'});
      const sc = STATUS_CLASS[s.status] || 'pending';
      const sl = STATUS_LABEL[s.status] || 'Unknown';
      return `<tr>
        <td style="color:rgba(15,20,30,0.6)">${dateStr}</td>
        <td style="color:rgba(15,20,30,0.6)">${esc(s.provider||'—')}</td>
        <td style="color:rgba(15,20,30,0.6)">${esc(s.period||'—')}</td>
        <td style="text-align:right;font-family:'JetBrains Mono',monospace;font-size:11.5px">${fmtK(s.volume)}</td>
        <td style="text-align:right">${s.effective_rate ? `<span class="rate-pill ${ratePillClass(s.effective_rate)}">${fmtP(s.effective_rate)}</span>` : '—'}</td>
        <td><span class="status-badge ${sc}">${sl}</span></td>
      </tr>`;
    }).join('')}
    </tbody>
  </table>`;
}

function buildReportTab(latestSub, facts, merchant) {
  if (!latestSub) return '<div style="padding:40px;text-align:center;color:rgba(15,20,30,0.25)">No submissions yet.</div>';

  const hasReport = !!latestSub.report_html_path;
  const approveLabel = hasReport ? 'Regenerate report' : 'Approve &amp; generate report';

  const reportBanner = hasReport ? `
    <div class="report-ready-banner">
      <span class="rb-text">✓ Report generated</span>
      <button class="btn-open-report" onclick="openReport('${escA(latestSub.report_html_path)}')">
        <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Open report
      </button>
    </div>` : '';

  return `
    ${reportBanner}
    ${buildEditPanel(latestSub.id, facts)}
    <div class="modal-section">
      <div class="modal-section-label">Actions</div>
      <div class="modal-actions">
        <button class="btn-mark-reviewed" onclick="updateStatus(${latestSub.id},'reviewed')">✓ Mark as reviewed</button>
        <button class="btn-approve" id="btn-approve-${latestSub.id}" onclick="approveAndGenerate(${latestSub.id})">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
          ${approveLabel}
        </button>
        <button class="btn-mark-sent" onclick="updateStatus(${latestSub.id},'sent')">→ Mark as sent to client</button>
      </div>
      <div id="report-status-${latestSub.id}" style="margin-top:10px;font-size:12px;color:rgba(15,20,30,0.4)"></div>
    </div>`;
}

/* ─────────────────────────────────────────────────────────────
   EDIT PANEL (for report corrections)
───────────────────────────────────────────────────────────── */
const PRICING_OPTS=['','Single-rate','Blended','Interchange-plus','Interchange-plus-plus','Subscription','Unknown'];
const LCR_OPTS=['','On','Off','Partial','Unknown'];
function selectHtml(field,value,opts){return`<select class="edit-select" data-field="${field}">`+opts.map(o=>`<option value="${escA(o)}" ${String(value||'')=== o?'selected':''}>${esc(o)||'—'}</option>`).join('')+`</select>`;}

function buildEditPanel(id, f) {
  const num = v => (v==null||v==='')?'':v;
  const obs = Array.isArray(f.observations) ? f.observations.join('\n') : '';
  return `<div class="modal-section" style="padding-top:16px">
    <button class="edit-panel-toggle" id="edit-toggle-${id}" onclick="toggleEditPanel('${id}')">
      <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
      Review &amp; correct extracted data before generating
      <span class="toggle-icon">▼</span>
    </button>
    <div class="edit-panel" id="edit-panel-${id}">
      <div class="edit-grid">
        <div class="edit-field"><div class="edit-field-label">Provider</div><input class="edit-input" type="text" data-field="provider" value="${escA(f.provider||'')}"></div>
        <div class="edit-field"><div class="edit-field-label">Period</div><input class="edit-input" type="text" data-field="period" value="${escA(f.period||'')}"></div>
      </div>
      <div class="edit-grid">
        <div class="edit-field"><div class="edit-field-label">Card volume (AUD)</div><input class="edit-input" type="number" step="any" data-field="volume" value="${num(f.volume)}"></div>
        <div class="edit-field"><div class="edit-field-label">Total fees (AUD, GST incl.)</div><div class="edit-field-hint">Effective rate recalculated from volume &amp; fees.</div><input class="edit-input" type="number" step="any" data-field="totalFees" value="${num(f.totalFees)}"></div>
      </div>
      <div class="edit-grid-3">
        <div class="edit-field"><div class="edit-field-label">Transactions</div><input class="edit-input" type="number" step="1" data-field="transactions" value="${num(f.transactions)}"></div>
        <div class="edit-field"><div class="edit-field-label">Monthly fee</div><input class="edit-input" type="number" step="any" data-field="monthlyFee" value="${num(f.monthlyFee)}"></div>
        <div class="edit-field"><div class="edit-field-label">Terminal fees</div><input class="edit-input" type="number" step="any" data-field="terminalFees" value="${num(f.terminalFees)}"></div>
      </div>
      <div class="edit-grid-3">
        <div class="edit-field"><div class="edit-field-label">Provider rate</div><input class="edit-input" type="text" data-field="providerRate" value="${escA(f.providerRate||'')}" placeholder="e.g. 0.12%"></div>
        <div class="edit-field"><div class="edit-field-label">Pricing model</div>${selectHtml('pricingModel',f.pricingModel,PRICING_OPTS)}</div>
        <div class="edit-field"><div class="edit-field-label">LCR status</div>${selectHtml('lcrStatus',f.lcrStatus,LCR_OPTS)}</div>
      </div>
      <div class="edit-field"><div class="edit-field-label">Factual observations</div><div class="edit-field-hint">One per line.</div><textarea class="edit-textarea" data-field="observations">${esc(obs)}</textarea></div>
      <div class="edit-field"><div class="edit-field-label">Admin notes (internal only)</div><textarea class="edit-textarea" data-field="adminNotes" placeholder="Extra context for Claude — won't appear in report."></textarea></div>
      <div class="edit-panel-note">✦ Corrections are applied before the report is written and saved back to the submission.</div>
    </div>
  </div>`;
}

function toggleEditPanel(id) {
  document.getElementById('edit-toggle-'+id).classList.toggle('open');
  document.getElementById('edit-panel-'+id).classList.toggle('open');
}

function readEditOverrides(id) {
  const panel = document.getElementById('edit-panel-'+id); if (!panel) return {};
  const get = sel => { const el = panel.querySelector(sel); return el ? el.value.trim() : ''; };
  const ov = {};
  ['provider','period','providerRate','pricingModel','lcrStatus'].forEach(k => { const v = get(`[data-field="${k}"]`); if(v) ov[k]=v; });
  ['volume','totalFees','transactions','monthlyFee','terminalFees'].forEach(k => { const v = get(`[data-field="${k}"]`); if(v!=='') ov[k]=Number(v); });
  const obs = get('[data-field="observations"]'); if(obs) ov.observations = obs.split('\n').map(l=>l.trim()).filter(Boolean);
  const notes = get('[data-field="adminNotes"]'); if(notes) ov.adminNotes = notes;
  return ov;
}

/* ─────────────────────────────────────────────────────────────
   STATUS & REPORT ACTIONS
───────────────────────────────────────────────────────────── */
async function updateStatus(id, status) {
  const data = await api('updateStatus', { id, status });
  if (!data) return;
  // Update local state
  allMerchants = allMerchants.map(m => {
    if (m.latest_submission_id == id) return { ...m, latest_status: status };
    return m;
  });
  updateDashboard();
  applyMerchantFilter();
  updateSidebarBadge();
  closeModalBtn();
}

async function approveAndGenerate(id) {
  const btn = document.getElementById('btn-approve-'+id);
  const statusEl = document.getElementById('report-status-'+id);
  const overrides = readEditOverrides(id);
  if (btn) { btn.disabled = true; btn.innerHTML = '⏳ Generating report…'; }
  if (statusEl) statusEl.textContent = 'Claude is writing the personalised report…';
  try {
    const res = await fetch('/api/generate-report', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ submissionId: id, overrides })
    });
    if (res.status === 401) { showLoginScreen(); return; }
    const data = await res.json();
    if (!res.ok) throw new Error(data.error || 'Generation failed');
    if (statusEl) statusEl.innerHTML = `<span style="color:#0E9F6E;font-weight:600">✓ Report generated.</span> <button class="btn-open-report" style="padding:6px 14px;margin-left:8px" onclick="openReport('${escA(data.htmlPath)}')">Open report</button>`;
    if (btn) { btn.disabled = false; btn.innerHTML = 'Regenerate report'; }
    await loadMerchants();
  } catch(err) {
    if (statusEl) statusEl.innerHTML = `<span style="color:#DC2626">Error: ${esc(err.message)}</span>`;
    if (btn) { btn.disabled = false; btn.innerHTML = 'Approve &amp; generate report'; }
  }
}

async function openReport(htmlPath) {
  try {
    const data = await api('getReportHtml', { htmlPath });
    if (!data) return;
    window.open(URL.createObjectURL(new Blob([data.html], {type:'text/html'})), '_blank');
  } catch(err) { alert('Could not open report: ' + err.message); }
}

/* ─────────────────────────────────────────────────────────────
   MODAL HELPERS
───────────────────────────────────────────────────────────── */
function closeModal(e) { if (e.target === document.getElementById('modal-overlay')) closeModalBtn(); }
function closeModalBtn() { document.getElementById('modal-overlay').classList.remove('open'); document.body.style.overflow = ''; }
document.addEventListener('keydown', e => { if (e.key === 'Escape') { closeModalBtn(); closeAvatarMenu(); } });

/* ─────────────────────────────────────────────────────────────
   AVATAR MENU
───────────────────────────────────────────────────────────── */
function toggleAvatarMenu(e) { e.stopPropagation(); document.getElementById('nav-avatar-menu').classList.toggle('open'); }
function closeAvatarMenu() { document.getElementById('nav-avatar-menu').classList.remove('open'); }
document.addEventListener('click', () => closeAvatarMenu());

/* ─────────────────────────────────────────────────────────────
   AUTH / LOGIN
───────────────────────────────────────────────────────────── */
function showLoginScreen() {
  document.getElementById('app-shell').style.display = 'none';
  document.getElementById('login-screen').style.display = 'flex';
  document.getElementById('login-password').focus();
}
function showAppShell() {
  document.getElementById('login-screen').style.display = 'none';
  document.getElementById('app-shell').style.display = 'grid';
}
async function handleLogin(e) {
  e.preventDefault();
  const pwInput = document.getElementById('login-password');
  const errEl = document.getElementById('login-error');
  const btn = document.getElementById('login-submit-btn');
  errEl.textContent = '';
  btn.disabled = true; btn.textContent = 'Signing in…';
  try {
    const res = await fetch('/api/admin-login', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ password: pwInput.value })
    });
    const data = await res.json().catch(() => ({}));
    if (!res.ok) throw new Error(data.error || 'Sign in failed');
    pwInput.value = '';
    showAppShell();
    initDashboard();
  } catch(err) {
    errEl.textContent = err.message;
  } finally {
    btn.disabled = false; btn.textContent = 'Sign in';
  }
  return false;
}
async function handleLogout() {
  try { await fetch('/api/admin-logout', { method: 'POST' }); } catch {}
  showLoginScreen();
}

/* ─────────────────────────────────────────────────────────────
   INIT
───────────────────────────────────────────────────────────── */
let dashboardInitialised = false;
function initDashboard() {
  if (dashboardInitialised) return;
  dashboardInitialised = true;
  setInterval(loadMerchants, 60000);
}
(async function start() {
  const authenticated = await loadMerchants();
  if (authenticated) {
    showAppShell();
    initDashboard();
  }
})();
</script>
