  // Commercial intelligence
  const commercialHtml = commercialIntel ? `
    <div class="pit-grid">
      <div class="pit-panel">
        <div class="pit-panel-title">Pricing Analysis</div>
        <div class="pit-row"><span class="pit-row-label">Pricing model</span><span class="pit-row-val">${esc(commercialIntel.pricingModel?.model||'—')}</span></div>
        <div class="pit-row"><span class="pit-row-label">Transparency</span><span class="pit-row-val">${esc(commercialIntel.pricingModel?.transparency||'—')}</span></div>
        <div class="pit-row"><span class="pit-row-label">Provider margin</span><span class="pit-row-val">${esc(commercialIntel.providerMargin?.observed||'—')}</span></div>
        <div class="pit-row"><span class="pit-row-label">Margin position</span><span class="pit-row-val">${esc(commercialIntel.providerMargin?.position||'—')}</span></div>
        <div class="pit-row"><span class="pit-row-label">Benchmark position</span><span class="pit-row-val" style="font-size:11px">${esc(commercialIntel.benchmark?.position||'—')}</span></div>
      </div>
      <div class="pit-panel">
        <div class="pit-panel-title">Cost Drivers</div>
        ${(commercialIntel.costDrivers||[]).map(d => `
          <div class="pit-row"><span class="pit-row-label">${esc(d.label)}</span><span class="pit-row-val">${d.pct}% · ${fmtK(d.amount)}</span></div>`).join('')}
        ${commercialIntel.commercialRead?.length ? `<div style="margin-top:10px;padding-top:10px;border-top:1px solid rgba(15,20,30,0.08)">${commercialIntel.commercialRead.map(r => `<div style="font-size:11.5px;color:rgba(15,20,30,0.45);margin-bottom:6px">· ${esc(r)}</div>`).join('')}</div>` : ''}
      </div>
    </div>` : '';

  // Findings
  const findingsHtml = findings.length ? `
    <div class="modal-section">
      <div class="modal-section-label">Key Findings</div>
      ${findings.filter(f => f.title || f.id).map(f => `
        <div class="pit-finding-item">
          ${confidenceDot(f.confidence)}
          <div>
            <div class="pit-finding-title">${esc(f.title||f.id)}</div>
            ${f.summary ? `<div style="font-size:11px;color:rgba(15,20,30,0.35);margin-top:2px">${esc(f.summary)}</div>` : ''}
          </div>
        </div>`).join('')}
    </div>` : '';

  // Risks
  const risks = riskIntel?.risks || [];
  const risksHtml = risks.length ? `
    <div class="modal-section">
      <div class="modal-section-label">Risk Flags</div>
      ${risks.map(r => `
        <div class="modal-alert warn" style="margin-bottom:6px">
          <strong>${esc(r.title||r.id)}</strong>${r.detail ? esc(r.detail) : ''}
        </div>`).join('')}
    </div>` : '';

  // Data quality
  const dqHtml = dataQuality ? (() => {
    const level = dataQuality.qualityLevel || dataQuality.level || 'Unknown';
    const pct = level === 'High' ? 100 : level === 'Medium' ? 60 : 30;
    const cls = level === 'High' ? '' : level === 'Medium' ? 'med' : 'low';
    const gaps = dataQuality.gaps || [];
    return `
      <div class="modal-section">
        <div class="modal-section-label">Data Quality</div>
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:10px">
