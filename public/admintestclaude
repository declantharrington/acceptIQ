<script>
/* ─────────────────────────────────────────────────────────────
   STATE
───────────────────────────────────────────────────────────── */
let allMerchants = [];
let currentMerchantFilter = 'all';
let currentMerchantSearch = '';

/* ─────────────────────────────────────────────────────────────
   HELPERS
───────────────────────────────────────────────────────────── */
const fmtD = n => (n != null && n !== '') ? '$' + Number(n).toLocaleString('en-AU', {minimumFractionDigits:2, maximumFractionDigits:2}) : '—';
const fmtK = n => { if (n == null || n === '') return '—'; const v = Number(n); return v >= 1000000 ? '$' + (v/1000000).toFixed(1) + 'M' : v >= 1000 ? '$' + (v/1000).toFixed(0) + 'k' : fmtD(v); };
const fmtP = n => (n != null && n !== '') ? Number(n).toFixed(2) + '%' : '—';
const esc  = v => (v == null ? '' : String(v)).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
const escA = v => esc(v).replace(/"/g,'&quot;');
function parseJSON(str, fallback) { try { return str ? JSON.parse(str) : fallback; } catch { return fallback; } }
function ratePillClass(r) { if (!r) return ''; return r > 1.7 ? 'rate-hi' : r > 1.3 ? 'rate-mid' : 'rate-lo'; }

const STATUS_LABEL = { pending_review:'Pending review', reviewed:'Reviewed', approved:'Report ready', sent:'Sent to client' };
const STATUS_CLASS = { pending_review:'pending', reviewed:'reviewed', approved:'approved', sent:'sent' };

function confidenceDot(c) {
  const cls = c === 'Confirmed' ? 'conf-confirmed' : c === 'Likely' ? 'conf-likely' : 'conf-estimated';
  return `<span class="confidence-dot ${cls}"></span>`;
}

function checkFeeReconciliation(f) {
  const total = Number(f?.totalFees);
  const items = Array.isArray(f?.feeBreakdown) ? f.feeBreakdown : [];
  if (!total || !items.length) return null;
  const sum = items.reduce((a, b) => a + (Number(b.amount) || 0), 0);
  const pct = Math.abs(sum - total) / total * 100;
  if (pct <= 5) return null;
  return { total, sum, diff: sum - total, pct };
}

/* ─────────────────────────────────────────────────────────────
   API HELPER
───────────────────────────────────────────────────────────── */
async function api(action, params = {}) {
  const res = await fetch('/api/admin-data', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ action, ...params })
  });
  if (res.status === 401) { showLoginScreen(); return null; }
  if (!res.ok) {
    const e = await res.json().catch(() => ({}));
    throw new Error(e.error || ('HTTP ' + res.status));
  }
  return res.json();
}

/* ─────────────────────────────────────────────────────────────
   NAVIGATION
───────────────────────────────────────────────────────────── */
function showPage(id, btn) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(b => b.classList.remove('active'));
  document.getElementById('page-' + id).classList.add('active');
  if (btn) btn.classList.add('active');
}

/* ─────────────────────────────────────────────────────────────
   LOAD DATA
───────────────────────────────────────────────────────────── */
async function loadMerchants() {
  try {
    const data = await api('listMerchants');
    if (!data) return false;
    allMerchants = data.merchants || [];
    updateDashboard();
    applyMerchantFilter();
    updateSidebarBadge();
    return true;
  } catch(err) {
    document.getElementById('merchants-tbody').innerHTML =
      `<tr class="empty-row"><td colspan="8">Could not load merchants: ${esc(err.message)}</td></tr>`;
    return false;
  }
}

/* ─────────────────────────────────────────────────────────────
   DASHBOARD
───────────────────────────────────────────────────────────── */
function updateDashboard() {
  const total   = allMerchants.length;
  const pending = allMerchants.filter(m => m.latest_status === 'pending_review').length;
  const pitCount = allMerchants.filter(m => m.latest_pit_id).length;
  const totalOpp = allMerchants.reduce((sum, m) => sum + (m.quantified_annual_opportunity || 0), 0);

  document.getElementById('dash-merchants').textContent = total;
  document.getElementById('dash-pending').textContent   = pending;
  document.getElementById('dash-pit-count').textContent = pitCount;
  document.getElementById('dash-opportunity').textContent = totalOpp > 0 ? fmtK(totalOpp) : '—';
  if (pending > 0) document.getElementById('dash-pending-note').textContent = 'Needs attention';

  // Recent merchants table on dashboard
  const recent = allMerchants.slice(0, 8);
  document.getElementById('dash-merchants-tbody').innerHTML = recent.length
    ? recent.map(m => {
        const topOpp = m.top_opportunities?.[0];
        const topFind = m.key_findings?.[0];
        const sc = STATUS_CLASS[m.latest_status] || 'pending';
        const sl = STATUS_LABEL[m.latest_status] || 'No submissions';
        return `<tr onclick="openMerchant(${m.id}); showPage('merchants', document.querySelectorAll('.nav-item')[1])">
          <td class="primary">${esc(m.company_name)}<br><span style="font-size:11px;color:rgba(15,20,30,0.3);font-weight:400">${esc(m.industry||'')}</span></td>
          <td>${esc(m.latest_provider||'—')}</td>
          <td>${m.latest_effective_rate ? `<span class="rate-pill ${ratePillClass(m.latest_effective_rate)}">${fmtP(m.latest_effective_rate)}</span>` : '—'}</td>
          <td>${m.quantified_annual_opportunity ? `<span class="opp-pill">${fmtK(m.quantified_annual_opportunity)}</span>` : '—'}</td>
          <td style="font-size:11.5px;color:rgba(15,20,30,0.55)">${topFind ? esc(topFind.title) : '—'}</td>
          <td><span class="status-badge ${sc}">${sl}</span></td>
        </tr>`;
      }).join('')
    : `<tr class="empty-row"><td colspan="6">No merchants yet. Submit a statement to get started.</td></tr>`;
}

function updateSidebarBadge() {
  const n = allMerchants.filter(m => m.latest_status === 'pending_review').length;
  document.getElementById('sidebar-pending').textContent = n || '';
  document.getElementById('nav-pending-count').textContent = n + ' pending';
}

/* ─────────────────────────────────────────────────────────────
   MERCHANT LIST
───────────────────────────────────────────────────────────── */
function setMerchantFilter(filter, btn) {
  currentMerchantFilter = filter;
  document.querySelectorAll('.fpill').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  applyMerchantFilter();
}

function applyMerchantFilter() {
  currentMerchantSearch = document.getElementById('merchant-search').value.trim().toLowerCase();
  let list = allMerchants;

  if (currentMerchantFilter !== 'all') {
    list = list.filter(m => m.latest_status === currentMerchantFilter);
  }
  if (currentMerchantSearch) {
    list = list.filter(m =>
      [m.company_name, m.contact_name, m.contact_email, m.latest_provider, m.industry]
        .filter(Boolean).join(' ').toLowerCase().includes(currentMerchantSearch)
    );
  }

  document.getElementById('merchant-count').textContent =
    `${list.length} merchant${list.length === 1 ? '' : 's'}${currentMerchantSearch || currentMerchantFilter !== 'all' ? ' (filtered)' : ''}`;

  renderMerchants(list);
}

function renderMerchants(merchants) {
  if (!merchants.length) {
    document.getElementById('merchants-tbody').innerHTML =
      `<tr class="empty-row"><td colspan="8">${allMerchants.length ? 'No matching merchants.' : 'No merchants yet.'}</td></tr>`;
    return;
  }

  document.getElementById('merchants-tbody').innerHTML = merchants.map(m => {
    const sc = STATUS_CLASS[m.latest_status] || 'pending';
    const sl = STATUS_LABEL[m.latest_status] || 'No submissions';
    const reconFlag = ''; // checked inside modal
    const hasPit = !!m.latest_pit_id;

    return `<tr onclick="openMerchant(${m.id})">
      <td class="primary">
        ${esc(m.company_name)}${reconFlag}
        <br><span style="font-size:11px;color:rgba(15,20,30,0.3);font-weight:400">${esc(m.contact_name||'')}${m.contact_email ? ' · ' + esc(m.contact_email) : ''}</span>
      </td>
      <td>${esc(m.latest_provider||'—')}<br><span style="font-size:10px;color:rgba(15,20,30,0.3)">${esc(m.latest_period||'')}</span></td>
      <td>${m.latest_effective_rate ? `<span class="rate-pill ${ratePillClass(m.latest_effective_rate)}">${fmtP(m.latest_effective_rate)}</span>` : '—'}</td>
      <td class="mono">${fmtK(m.latest_volume)}</td>
      <td>${m.quantified_annual_opportunity ? `<span class="opp-pill">${fmtK(m.quantified_annual_opportunity)}</span>` : hasPit ? '<span style="color:rgba(15,20,30,0.25);font-size:11px">No opportunity quantified</span>' : '—'}</td>
      <td style="color:rgba(15,20,30,0.5)">${m.submission_count}</td>
      <td><span class="status-badge ${sc}">${sl}</span>${m.latest_report_html_path ? '<span class="report-dot"></span>' : ''}</td>
      <td style="text-align:right">
        <div style="display:flex;gap:6px;justify-content:flex-end">
          ${m.latest_report_html_path ? `<button class="action-btn blue" onclick="event.stopPropagation();openReport('${escA(m.latest_report_html_path)}')">Report ↗</button>` : ''}
          <button class="action-btn ghost" onclick="event.stopPropagation();openMerchant(${m.id})">View →</button>
        </div>
