  // Opportunities
  const oppsHtml = opportunities.length ? `
    <div class="modal-section">
      <div class="modal-section-label">Quantified Opportunities</div>
      ${opportunities.map(o => `
        <div class="pit-opp-item">
          <div style="flex:1">
            <div class="pit-opp-title">${confidenceDot(o.confidence)}${esc(o.title||o.id)}</div>
            <div class="pit-opp-meta">${esc(o.confidence)} · ${esc(o.urgency||'')} urgency</div>
          </div>
          <div class="pit-opp-value">${o.estimatedAnnualValue ? fmtK(o.estimatedAnnualValue) + '/yr' : 'Strategic'}</div>
