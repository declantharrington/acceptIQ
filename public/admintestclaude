<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>acceptorIQ — Operations Portal</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html, body { height: 100%; overflow: hidden; }
body { font-family: 'Inter', sans-serif; background: #F3F4F9; color: #12141C; -webkit-font-smoothing: antialiased; font-size: 13.5px; font-weight: 400; }

/* ── SHELL ── */
.shell { display: grid; grid-template-columns: 220px 1fr; grid-template-rows: 56px 1fr; height: 100vh; }

/* ── NAV ── */
.nav { grid-column: 1 / -1; display: flex; align-items: center; justify-content: space-between; padding: 0 24px 0 0; background: #FFFFFF; border-bottom: 1px solid #ECEDF3; z-index: 10; }
.nav-brand { display: flex; align-items: center; height: 56px; width: 220px; padding: 0 20px; }
.nav-logo { height: 24px; width: auto; display: block; }
.nav-mark { position: relative; width: 18px; height: 16px; display: inline-block; flex-shrink: 0; margin-right: 10px; }
.nav-mark span { position: absolute; bottom: 0; width: 6px; height: 16px; border-radius: 2px; background: #12141C; }
.nav-mark span:first-child { left: 3px; transform: skewX(-30deg); }
.nav-mark span:last-child  { right: 3px; height: 11px; transform: skewX(30deg); }
.nav-word { font-weight: 600; letter-spacing: -0.03em; color: rgba(15,20,30,.92); font-size: 15px; }
.nav-word b { font-weight: 700; color: #3654D6; }
.nav-right { display: flex; align-items: center; gap: 16px; }
.nav-system { display: flex; align-items: center; gap: 7px; font-size: 11px; color: rgba(15,20,30,0.4); }
.sys-dot { width: 6px; height: 6px; border-radius: 50%; background: #0E9F6E; animation: syspulse 2.5s ease-in-out infinite; }
@keyframes syspulse { 0%,100%{opacity:1} 50%{opacity:.4} }
.nav-badge-count { font-size: 11px; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; background: rgba(54,84,214,0.15); color: #3654D6; padding: 4px 10px; border-radius: 100px; }
.nav-avatar { width: 28px; height: 28px; border-radius: 50%; background: rgba(54,84,214,0.2); border: 1px solid rgba(54,84,214,0.3); display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 600; color: #3654D6; cursor: pointer; }
.nav-avatar-wrap { position: relative; }
.nav-avatar-menu { display: none; position: absolute; top: 38px; right: 0; min-width: 140px; background: #FFFFFF; border: 1px solid #ECEDF3; border-radius: 10px; z-index: 50; box-shadow: 0 8px 24px rgba(15,20,30,0.12); overflow: hidden; }
.nav-avatar-menu.open { display: block; }
.nav-avatar-menu-item { width: 100%; text-align: left; padding: 10px 14px; background: none; border: none; color: rgba(15,20,30,0.6); font-family: 'Inter', sans-serif; font-size: 12.5px; cursor: pointer; transition: background 0.12s, color 0.12s; }
.nav-avatar-menu-item:hover { background: rgba(15,20,30,0.07); color: rgba(15,20,30,0.9); }
.nav-avatar-menu-item.danger:hover { background: rgba(220,38,38,0.1); color: #DC2626; }

/* ── SIDEBAR ── */
.sidebar { background: #FFFFFF; border-right: 1px solid #ECEDF3; display: flex; flex-direction: column; padding: 16px 12px; overflow-y: auto; gap: 2px; }
.sidebar::-webkit-scrollbar { width: 0; }
.sidebar-section-label { font-size: 10px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(15,20,30,0.2); padding: 0 8px; margin: 16px 0 6px; }
.sidebar-section-label:first-child { margin-top: 0; }
.nav-item { display: flex; align-items: center; gap: 10px; padding: 9px 10px; border: 1px solid transparent; background: transparent; color: rgba(15,20,30,0.45); cursor: pointer; font-family: 'Inter', sans-serif; font-size: 12.5px; font-weight: 500; transition: all 0.12s; width: 100%; text-align: left; border-radius: 9px; }
.nav-item:hover { background: rgba(15,20,30,0.045); color: rgba(15,20,30,0.85); border-color: transparent; }
.nav-item.active { background: #3654D6; color: #FFFFFF; border-color: transparent; box-shadow: 0 4px 12px rgba(54,84,214,0.28); }
.nav-item-icon { font-size: 14px; width: 16px; text-align: center; flex-shrink: 0; color: rgba(15,20,30,0.32); transition: color 0.12s; }
.nav-item.active .nav-item-icon { color: #FFFFFF; }
.nav-item-badge { margin-left: auto; font-size: 10px; font-weight: 600; padding: 2px 7px; border-radius: 100px; background: rgba(180,83,9,0.15); color: #B45309; }
.nav-item.active .nav-item-badge { background: rgba(255,255,255,0.25); color: #FFFFFF; }
.nav-spacer { flex: 1; }
.sidebar-footer { padding: 12px 10px; border-top: 1px solid rgba(15,20,30,0.08); font-size: 11px; color: rgba(15,20,30,0.2); }

/* ── CONTENT ── */
.content { overflow-y: auto; background: #F3F4F9; }
.content::-webkit-scrollbar { width: 5px; }
.content::-webkit-scrollbar-thumb { background: rgba(15,20,30,0.08); border-radius: 2px; }
.page { display: none; padding: 32px 36px; min-height: 100%; }
.page.active { display: block; }
.page-head { margin-bottom: 28px; display: flex; align-items: flex-start; justify-content: space-between; gap: 16px; }
.page-head-left { flex: 1; }
.page-title { font-size: 22px; font-weight: 700; letter-spacing: -0.02em; color: rgba(15,20,30,.92); margin-bottom: 4px; }
.page-sub { font-size: 13.5px; color: rgba(15,20,30,0.5); margin-top: 2px; }

/* ── STAT CARDS ── */
.stats-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 12px; margin-bottom: 24px; }
.stat-card { background: #FFFFFF; border: 1px solid #ECEDF3; border-radius: 16px; padding: 20px; box-shadow: 0 1px 2px rgba(15,20,30,0.03), 0 8px 20px rgba(15,20,30,0.04); }
.stat-card-val { font-size: 26px; font-weight: 700; letter-spacing: -0.02em; color: #12141C; margin-bottom: 4px; }
.stat-card-lbl { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: rgba(15,20,30,0.3); }
.stat-card-delta { font-size: 11px; margin-top: 8px; color: rgba(14,159,110,0.8); }

/* ── MERCHANTS TABLE ── */
.toolbar { display: flex; align-items: center; gap: 10px; margin-bottom: 12px; }
.search-wrap { position: relative; flex: 1; min-width: 200px; }
.search-icon { position: absolute; left: 10px; top: 50%; transform: translateY(-50%); width: 13px; height: 13px; color: rgba(15,20,30,0.3); pointer-events: none; }
.search-input { width: 100%; font-family: 'Inter', sans-serif; font-size: 12.5px; padding: 9px 10px 9px 32px; background: #FFFFFF; border: 1px solid #E4E6EF; color: #12141C; border-radius: 9px; }
.search-input::placeholder { color: rgba(15,20,30,0.3); }
.search-input:focus { outline: none; border-color: rgba(54,84,214,0.4); background: rgba(54,84,214,0.04); }
.filter-pills { display: flex; gap: 6px; margin-bottom: 12px; flex-wrap: wrap; }
.fpill { font-family: 'Inter', sans-serif; font-size: 11px; font-weight: 500; padding: 5px 12px; border-radius: 100px; border: 1px solid rgba(15,20,30,0.1); background: none; color: rgba(15,20,30,0.4); cursor: pointer; transition: all 0.12s; }
.fpill.active { background: rgba(54,84,214,0.12); border-color: rgba(54,84,214,0.35); color: #3654D6; }
.fpill:hover:not(.active) { border-color: rgba(15,20,30,0.2); color: rgba(15,20,30,0.65); }
.results-count { font-size: 12px; color: rgba(15,20,30,0.45); margin-bottom: 10px; }
.table-wrap { background: #FFFFFF; border: 1px solid #ECEDF3; border-radius: 16px; overflow: hidden; box-shadow: 0 1px 2px rgba(15,20,30,0.03), 0 8px 20px rgba(15,20,30,0.04); }
.rtable { width: 100%; border-collapse: collapse; }
.rtable th { padding: 12px 16px; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: rgba(15,20,30,0.4); text-align: left; border-bottom: 1px solid #ECEDF3; background: #FAFAFD; white-space: nowrap; user-select: none; }
.rtable td { padding: 14px 16px; border-top: 1px solid #F1F2F7; font-size: 12.5px; color: rgba(15,20,30,0.7); vertical-align: middle; }
.rtable tr:hover td { background: rgba(15,20,30,0.05); cursor: pointer; }
.rtable td.primary { font-weight: 500; color: rgba(15,20,30,0.85); }
.rtable td.mono { font-family: 'JetBrains Mono', monospace; font-size: 11.5px; }
.loading-row td { text-align: center; padding: 60px 20px; color: rgba(15,20,30,0.3); font-size: 13px; }
.empty-row td { text-align: center; padding: 50px 20px; color: rgba(15,20,30,0.25); font-size: 13px; }

/* ── STATUS PILLS ── */
.status-badge { display: inline-flex; align-items: center; font-size: 10px; font-weight: 600; padding: 3px 10px; border-radius: 100px; }
.status-badge.pending  { background: rgba(180,83,9,0.15); color: #B45309; }
.status-badge.reviewed { background: rgba(15,20,30,0.08); color: rgba(15,20,30,0.5); }
.status-badge.approved { background: rgba(14,159,110,0.15); color: #0E9F6E; }
.status-badge.sent     { background: rgba(54,84,214,0.15); color: #3654D6; }
.report-dot { display: inline-block; width: 6px; height: 6px; border-radius: 50%; background: #0E9F6E; margin-left: 6px; box-shadow: 0 0 6px rgba(14,159,110,0.5); vertical-align: middle; }
.rate-pill { display: inline-block; font-size: 11px; font-weight: 600; padding: 2px 8px; border-radius: 100px; }
.rate-hi  { background: rgba(220,38,38,0.12); color: #DC2626; }
.rate-mid { background: rgba(180,83,9,0.12); color: #B45309; }
.rate-lo  { background: rgba(14,159,110,0.12); color: #0E9F6E; }
.opp-pill { display: inline-block; font-size: 11px; font-weight: 600; padding: 2px 8px; border-radius: 100px; background: rgba(54,84,214,0.12); color: #3654D6; font-family: 'JetBrains Mono', monospace; }
.confidence-dot { display: inline-block; width: 6px; height: 6px; border-radius: 50%; margin-right: 5px; }
.conf-confirmed { background: #0E9F6E; }
.conf-likely    { background: #3654D6; }
.conf-estimated { background: #B45309; }

/* ── ACTION BUTTONS ── */
.action-btn { font-family: 'Inter', sans-serif; font-size: 11px; font-weight: 500; padding: 5px 10px; border: none; cursor: pointer; transition: background 0.12s; border-radius: 9px; }
.action-btn.ghost { background: rgba(15,20,30,0.08); color: rgba(15,20,30,0.55); }
.action-btn.ghost:hover { background: rgba(15,20,30,0.1); color: rgba(15,20,30,0.85); }
.action-btn.blue  { background: rgba(54,84,214,0.12); color: #3654D6; border: 1px solid rgba(54,84,214,0.25); }
.action-btn.blue:hover { background: rgba(54,84,214,0.22); }
.action-btn.green { background: rgba(14,159,110,0.12); color: #0E9F6E; border: 1px solid rgba(14,159,110,0.25); }
.action-btn.green:hover { background: rgba(14,159,110,0.22); }

/* ── MODAL ── */
.modal-overlay { position: fixed; inset: 0; z-index: 500; background: rgba(0,0,0,0.75); backdrop-filter: blur(8px); display: none; align-items: flex-start; justify-content: center; padding: 40px 20px; overflow-y: auto; }
.modal-overlay.open { display: flex; }
.modal { background: #FFFFFF; border: 1px solid #ECEDF3; border-radius: 18px; width: 100%; max-width: 800px; position: relative; margin: auto; overflow: hidden; box-shadow: 0 24px 64px rgba(15,20,30,0.18); }
.modal-close { position: absolute; top: 14px; right: 14px; width: 30px; height: 30px; border-radius: 50%; background: rgba(15,20,30,0.08); border: none; cursor: pointer; color: rgba(15,20,30,0.5); display: flex; align-items: center; justify-content: center; font-size: 14px; }
.modal-close:hover { background: rgba(15,20,30,0.14); }
.modal-header { background: linear-gradient(135deg,#EEF1FE 0%,#F7F8FC 100%); padding: 28px 32px; border-bottom: 1px solid #ECEDF3; }
.modal-eyebrow { font-size: 10px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(15,20,30,0.28); margin-bottom: 8px; }
.modal-title { font-size: 20px; font-weight: 700; letter-spacing: -0.02em; color: #12141C; margin-bottom: 4px; }
.modal-meta { font-size: 12px; color: rgba(15,20,30,0.3); }
.modal-contact { font-size: 12.5px; color: rgba(15,20,30,0.55); margin-top: 8px; line-height: 1.6; }
.modal-contact a { color: #3654D6; text-decoration: none; }
.modal-stats { display: grid; grid-template-columns: repeat(4,1fr); gap: 10px; margin-top: 18px; }
.modal-stat { padding: 12px; background: #F7F8FC; border-radius: 10px; text-align: center; }
.modal-stat-val { font-size: 16px; font-weight: 600; color: #12141C; display: block; margin-bottom: 3px; font-family: 'JetBrains Mono', monospace; }
.modal-stat-lbl { font-size: 10px; color: rgba(15,20,30,0.28); text-transform: uppercase; letter-spacing: 0.09em; }

/* ── MODAL BODY TABS ── */
.modal-tabs { display: flex; border-bottom: 1px solid rgba(15,20,30,0.08); padding: 0 32px; }
.modal-tab { padding: 12px 0; margin-right: 24px; font-size: 12px; font-weight: 500; color: rgba(15,20,30,0.4); cursor: pointer; border-bottom: 2px solid transparent; transition: all 0.12s; background: none; border-top: none; border-left: none; border-right: none; font-family: 'Inter', sans-serif; }
.modal-tab:hover { color: rgba(15,20,30,0.7); }
.modal-tab.active { color: #3654D6; border-bottom-color: #3654D6; }
.modal-body { padding: 24px 32px 32px; }
.modal-tab-pane { display: none; }
.modal-tab-pane.active { display: block; }

/* ── MODAL SECTIONS ── */
.modal-section { padding: 16px 0; border-bottom: 1px solid rgba(15,20,30,0.08); }
.modal-section:last-child { border-bottom: none; }
.modal-section-label { font-size: 10px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(15,20,30,0.28); margin-bottom: 10px; }
.modal-section-text { font-size: 13px; line-height: 1.72; color: rgba(15,20,30,0.55); }
.modal-table { width: 100%; border-collapse: collapse; }
.modal-table td { padding: 9px 0; border-bottom: 1px solid rgba(15,20,30,0.08); font-size: 13px; }
.modal-table td:first-child { color: rgba(15,20,30,0.4); width: 50%; }
.modal-table td:last-child { text-align: right; font-weight: 500; color: rgba(15,20,30,0.8); }
.modal-table tr:last-child td { border-bottom: none; }
.modal-alert { padding: 12px 14px; margin-bottom: 8px; font-size: 13px; line-height: 1.6; border-radius: 0 8px 8px 0; }
.modal-alert.warn { background: rgba(180,83,9,0.1); border-left: 3px solid #B45309; color: rgba(15,20,30,0.65); }
.modal-alert.good { background: rgba(14,159,110,0.1); border-left: 3px solid #0E9F6E; color: rgba(15,20,30,0.65); }
.modal-alert.info { background: rgba(54,84,214,0.1); border-left: 3px solid #3654D6; color: rgba(15,20,30,0.65); }
.modal-alert strong { font-weight: 600; display: block; margin-bottom: 3px; color: rgba(15,20,30,0.85); }
.obs-list { margin: 0; padding-left: 18px; }
.obs-list li { font-size: 13px; color: rgba(15,20,30,0.55); line-height: 1.7; margin-bottom: 4px; }
.program-box { background: #F7F8FC; border-radius: 10px; padding: 14px; font-size: 13px; line-height: 1.7; color: rgba(15,20,30,0.6); }

/* ── PIT INTELLIGENCE PANELS ── */
.pit-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 16px; }
.pit-panel { background: #FFFFFF; border: 1px solid #ECEDF3; border-radius: 14px; padding: 16px; box-shadow: 0 1px 2px rgba(15,20,30,0.03); }
.pit-panel-title { font-size: 10px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(15,20,30,0.28); margin-bottom: 12px; }
.pit-row { display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; padding: 8px 0; border-bottom: 1px solid rgba(15,20,30,0.07); font-size: 12.5px; }
.pit-row:last-child { border-bottom: none; }
.pit-row-label { color: rgba(15,20,30,0.45); flex: 1; }
.pit-row-val { color: rgba(15,20,30,0.85); font-weight: 500; text-align: right; }
.pit-opp-item { display: flex; align-items: flex-start; gap: 10px; padding: 10px 0; border-bottom: 1px solid rgba(15,20,30,0.07); }
.pit-opp-item:last-child { border-bottom: none; }
.pit-opp-title { font-size: 12.5px; font-weight: 500; color: rgba(15,20,30,0.8); margin-bottom: 2px; }
.pit-opp-meta { font-size: 11px; color: rgba(15,20,30,0.35); }
.pit-opp-value { font-size: 13px; font-weight: 600; color: #0E9F6E; font-family: 'JetBrains Mono', monospace; white-space: nowrap; }
.pit-finding-item { display: flex; align-items: flex-start; gap: 10px; padding: 8px 0; border-bottom: 1px solid rgba(15,20,30,0.07); }
.pit-finding-item:last-child { border-bottom: none; }
.pit-finding-title { font-size: 12.5px; color: rgba(15,20,30,0.7); }
.pit-quality-bar { height: 4px; background: rgba(15,20,30,0.08); margin-top: 6px; }
.pit-quality-fill { height: 100%; background: #0E9F6E; transition: width 0.4s ease; }
.pit-quality-fill.med { background: #B45309; }
.pit-quality-fill.low { background: #DC2626; }


/* ── DETAILED PIT VIEWER ── */
.pitv-hero { background: linear-gradient(135deg, rgba(54,84,214,0.08), rgba(54,84,214,0.02)); border: 1px solid rgba(54,84,214,0.18); border-radius: 14px; padding: 18px; margin-bottom: 16px; }
.pitv-version { font-family:'JetBrains Mono', monospace; font-size:11px; color:rgba(54,84,214,.8); margin-bottom:8px; }
.pitv-title { font-size:18px; font-weight:600; color:rgba(15,20,30,0.92); margin-bottom:8px; }
.pitv-sub { font-size:13px; line-height:1.7; color:rgba(15,20,30,0.5); }
.pitv-grid { display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:16px; }
.pitv-section { margin:18px 0; }
.pitv-section-title { font-size:10px; font-weight:700; letter-spacing:.14em; text-transform:uppercase; color:rgba(15,20,30,0.28); margin-bottom:10px; }
.pitv-card { background:#FFFFFF; border:1px solid #ECEDF3; border-radius:12px; padding:14px; margin-bottom:9px; box-shadow: 0 1px 2px rgba(15,20,30,0.03); }
details.pitv-card { cursor:pointer; }
details.pitv-card summary { list-style:none; }
details.pitv-card summary::-webkit-details-marker { display:none; }
.pitv-card-head { display:flex; align-items:flex-start; justify-content:space-between; gap:12px; }
.pitv-card-title { font-size:13px; font-weight:600; color:rgba(15,20,30,0.85); line-height:1.45; }
.pitv-card-meta { margin-top:4px; font-size:11px; color:rgba(15,20,30,0.32); }
.pitv-card-body { margin-top:10px; padding-top:10px; border-top:1px solid rgba(15,20,30,0.08); font-size:12.2px; line-height:1.7; color:rgba(15,20,30,0.55); }
.pitv-badges { display:flex; gap:6px; flex-wrap:wrap; justify-content:flex-end; }
.pitv-badge { font-size:10px; font-weight:700; letter-spacing:.03em; padding:3px 7px; border:1px solid rgba(15,20,30,0.1); background:rgba(15,20,30,0.06); color:rgba(15,20,30,0.55); white-space:nowrap; }
.pitv-badge.high, .pitv-badge.confirmed, .pitv-badge.positive { color:#0E9F6E; background:rgba(14,159,110,.10); border-color:rgba(14,159,110,.18); }
.pitv-badge.medium, .pitv-badge.estimated, .pitv-badge.likely { color:#B45309; background:rgba(180,83,9,.10); border-color:rgba(180,83,9,.18); }
.pitv-badge.low, .pitv-badge.needs-validation { color:#DC2626; background:rgba(220,38,38,.10); border-color:rgba(220,38,38,.18); }
.pitv-evidence { margin-top:8px; }
.pitv-evidence-item { display:flex; gap:8px; padding:6px 0; border-bottom:1px solid rgba(15,20,30,0.065); font-size:11.5px; color:rgba(15,20,30,0.45); }
.pitv-evidence-item:last-child { border-bottom:none; }
.pitv-evidence-source { min-width:120px; color:rgba(54,84,214,.65); font-family:'JetBrains Mono', monospace; font-size:10.5px; }
.pitv-code { white-space:pre-wrap; max-height:420px; overflow:auto; background:#181B22; border-radius:10px; border:1px solid rgba(15,20,30,0.08); padding:14px; font-family:'JetBrains Mono', monospace; font-size:11px; line-height:1.6; color:rgba(224,233,246,0.75); }
@media(max-width:800px){ .pitv-grid{grid-template-columns:1fr;} }


/* ── REPORT BANNER + ACTIONS ── */
.report-ready-banner { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; background: rgba(14,159,110,0.1); border: 1px solid rgba(14,159,110,0.25); padding: 14px 16px; margin-bottom: 16px; }
.report-ready-banner .rb-text { font-size: 13px; color: #0E9F6E; font-weight: 500; }
.modal-actions { display: flex; gap: 10px; margin-top: 20px; flex-wrap: wrap; }
.btn-mark-reviewed { background: rgba(14,159,110,0.15); color: #0E9F6E; border: 1px solid rgba(14,159,110,0.3); padding: 10px 18px; font-family: 'Inter', sans-serif; font-size: 13px; font-weight: 500; cursor: pointer; transition: background 0.15s; border-radius: 9px; }
.btn-mark-reviewed:hover { background: rgba(14,159,110,0.25); }
