        <tr><td>LCR status</td><td>${esc(facts.lcrStatus||'—')}</td></tr>
        <tr><td>Pricing model</td><td>${esc(facts.pricingModel||'—')}</td></tr>
        <tr><td>Debit mix</td><td>${facts.cardMix?.debit != null ? facts.cardMix.debit + '%' : '—'}</td></tr>
        <tr><td>Credit mix</td><td>${facts.cardMix?.credit != null ? facts.cardMix.credit + '%' : '—'}</td></tr>
      </table>
      ${Array.isArray(facts.observations) && facts.observations.length ? `
        <div style="margin-top:12px">
          <div class="modal-section-label">Observations</div>
          <ul class="obs-list">${facts.observations.map(o => `<li>${esc(o)}</li>`).join('')}</ul>
        </div>` : ''}
    </div>`;

  return `${headlineSummary}${oppsHtml}${commercialHtml}${findingsHtml}${risksHtml}${dqHtml}${factsHtml}`;
}


function buildPITViewerTab(pit, latestPit) {
  const observations = pit.commercialObservations || [];
  const understandings = pit.commercialUnderstanding || [];
  const priorities = pit.businessPriorities || [];
  const confidence = pit.confidenceProfile || {};
  const evidenceGraph = pit.evidenceGraph || null;
  const modulePlan = pit.modulePlan || [];
  const risks = pit.riskIntelligence?.risks || [];
  const gaps = pit.dataQuality?.gaps || [];

  const generated = latestPit?.generated_at || pit.generatedAt || null;

  return `
    <div class="pitv-hero">
      <div class="pitv-version">${esc(pit.version || latestPit?.pit_version || 'PIT')} ${generated ? '· ' + esc(new Date(generated).toLocaleString('en-AU')) : ''}</div>
      <div class="pitv-title">${esc(pit.caseSummary?.headline || 'Payments Intelligence Terminal result')}</div>
      <div class="pitv-sub">${esc(pit.caseSummary?.summary || 'This is the persisted PIT snapshot for this merchant. It shows what the engine understood, why it reached those conclusions, and which priorities it created.')}</div>
    </div>

    <div class="pitv-grid">
      <div class="pit-panel">
        <div class="pit-panel-title">Confidence Profile</div>
        ${Object.entries(confidence).map(([k,v]) => renderPitRow(labelise(k), v)).join('') || renderPitRow('Confidence', 'Not available')}
      </div>
      <div class="pit-panel">
        <div class="pit-panel-title">Case Intelligence</div>
        ${renderPitRow('Provider', pit.paymentsStack?.acquirerOrProvider || pit.facts?.provider || '—')}
        ${renderPitRow('Pricing model', pit.paymentsStack?.pricingModel || pit.facts?.pricingModel || '—')}
        ${renderPitRow('Effective rate', pit.metrics?.effectiveRate != null ? fmtP(pit.metrics.effectiveRate) : '—')}
        ${renderPitRow('Annual opportunity', pit.caseSummary?.quantifiedAnnualOpportunity ? fmtK(pit.caseSummary.quantifiedAnnualOpportunity) : 'To be confirmed')}
      </div>
    </div>

    ${renderPitPrioritySection(priorities)}
    ${renderPitUnderstandingSection(understandings)}
    ${renderPitObservationSection(observations)}
    ${renderPitRiskGapSection(risks, gaps)}
    ${renderPitModulePlanSection(modulePlan)}
    ${renderPitEvidenceGraphSection(evidenceGraph)}
    ${renderPitRawSection(pit)}
  `;
}

