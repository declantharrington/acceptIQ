          <div style="font-size:12px;font-weight:600;color:rgba(15,20,30,0.7);white-space:nowrap">${esc(level)}</div>
        </div>
        ${gaps.map(g => `<div style="font-size:12px;color:rgba(15,20,30,0.45);margin-bottom:4px">· ${esc(g.label)} — ${esc(g.reason||'')}</div>`).join('')}
      </div>`;
  })() : '';

  // Raw facts
  const factsHtml = `
    <div class="modal-section">
      <div class="modal-section-label">Statement Data</div>
      <table class="modal-table">
